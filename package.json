{
  "name": "boardgame-web-ts",
  "version": "1.0.0",
  "description": "Web based boardgame engine",
  "homepage": "https://github.com/HMHamster88/boardgame-web-ts#readme",
  "bugs": {
    "url": "https://github.com/HMHamster88/boardgame-web-ts/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HMHamster88/boardgame-web-ts.git"
  },
  "workspaces": [
    "common",
    "back",
    "front"
  ],
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "build-all": "npm run build-common && npm run build-front && npm run build-back",
    "make-common-link": "npm run make-link -w common",
    "build-common": "npm run build -w common && npm run make-common-link",
    "build-back": "npm run build -w back",
    "build-front": "npm run build -w front",
    "start": "npm run start --prefix ./back"
  },
  "dependencies": {
    "@types/unzipper": "^0.10.11",
    "all": "^0.0.0",
    "unzipper": "^0.12.5"
  },
  "overrides": {
    "vue": "3.5.38"
  }
}
