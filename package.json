{
  "name": "boardgame-web-ts",
  "version": "1.0.0",
  "description": "Web based boardgame engine",
  "homepage": "https://github.com/HMHamster88/boardgame-web-ts#readme",
  "bugs": {
    "url": "https://github.com/HMHamster88/boardgame-web-ts/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HMHamster88/boardgame-web-ts.git"
  },
  "workspaces": [
    "common",
    "back",
    "front",
    "games/catan/*",
    "games/cah/*"
  ],
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "build-all": "npm run build-common && npm run build-catan && npm run build-cah && npm run build-front && npm run build-back",
    "build-common": "npm run build -w common",
    "build-back": "npm run build -w back",
    "build-front": "npm run build -w front",
    "build-catan": "npm run build -w games/catan",
    "build-cah": "npm run build -w games/cah",
    "start": "npm run start --prefix ./back"
  },
  "dependencies": {
    "all": "^0.0.0"
  },
  "overrides": {
    "vue": "3.5.38"
  }
}