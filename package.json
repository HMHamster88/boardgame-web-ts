{
  "name": "boardgame-web-ts",
  "version": "1.0.0",
  "description": "Web based boardgame engine",
  "homepage": "https://github.com/HMHamster88/boardgame-web-ts#readme",
  "bugs": {
    "url": "https://github.com/HMHamster88/boardgame-web-ts/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HMHamster88/boardgame-web-ts.git"
  },
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "install-all": "npm run install-common && npm run install-back && npm run install-front && npm run install-catan-back && npm run install-catan-front && npm run install-cah-back && npm run install-cah-front",
    "install-common": "npm install --prefix ./common --legacy-peer-deps",
    "install-back": "npm install --prefix ./back --legacy-peer-deps",
    "install-front": "npm install --prefix ./front --legacy-peer-deps",
    "install-catan-back": "npm install --prefix ./games/catan/catan-back --legacy-peer-deps",
    "install-catan-front": "npm install --prefix ./games/catan/catan-front --legacy-peer-deps",
    "install-cah-back": "npm install --prefix ./games/cah/cah-back --legacy-peer-deps",
    "install-cah-front": "npm install --prefix ./games/cah/cah-front --legacy-peer-deps",
    "build-all": "npm run build-common && npm run build-catan-back && npm run build-catan-front && npm run build-cah-back && npm run build-cah-front && npm run build-front && npm run build-back",
    "build-common": "npm run build --prefix ./common",
    "build-back": "npm run build --prefix ./back",
    "build-front": "npm run build --prefix ./front",
    "build-catan-back": "npm run build --prefix ./games/catan/catan-back",
    "build-catan-front": "npm run build --prefix ./games/catan/catan-front",
    "build-cah-back": "npm run build --prefix ./games/cah/cah-back",
    "build-cah-front": "npm run build --prefix ./games/cah/cah-front",
    "start": "npm run start --prefix ./back"
  },
  "dependencies": {
    "all": "^0.0.0"
  }
}