{
  "name": "boardgame-web-back",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node src/app.ts",
    "build": "npm run clean && tsdown && npm run cp-public && npm run cp-env-to-bubdled",
    "build:sea": "npm run build && shx mkdir -p dist/sea && shx cp -r public dist/sea/public && node --build-sea sea-config.json && npm run cp-env-to-sea",
    "clean": "shx rm -rf dist",
    "cp-public": "shx cp -r ./public ./dist/bundled/public",
    "cp-env-to-bubdled": "shx cp .env.prod ./dist/bundled/.env",
    "cp-env-to-sea": "shx cp .env.prod ./dist/sea/.env",
    "dev": "nodemon",
    "set-path": "cross-env GREET=\"Joe\"",
    "get-path": "cross-env-shell \"echo Hello $GREET\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@types/express-ws": "^3.0.6",
    "boardgame-web-common": "file:../common",
    "connect-history-api-fallback": "^2.0.0",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-ws": "^5.0.2",
    "semver": "^7.6.3",
    "uuidv4": "^6.2.13"
  },
  "devDependencies": {
    "@types/connect-history-api-fallback": "^1.5.4",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "nodemon": "^3.1.14",
    "shx": "^0.4.0",
    "ts-node": "^10.9.2",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3"
  }
}
